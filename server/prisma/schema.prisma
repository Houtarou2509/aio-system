generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  username        String    @unique
  email           String    @unique
  passwordHash    String
  role            Role      @default(STAFF)
  permissions     String    @default("[]")
  twoFactorSecret String?
  twoFactorEnabled Boolean  @default(false)
  backupCodes     String   @default("[]")
  fullName        String?
  status          String    @default("active")
  lastLogin       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignments        Assignment[]
  issuedAgreementDocuments AgreementDocument[] @relation("AgreementDocumentIssuedBy")
  uploadedAgreementDocuments AgreementDocument[] @relation("AgreementDocumentSignedUploadedBy")
  auditLogs          AuditLog[]         @relation("PerformedBy")
  labelTemplates     LabelTemplate[]
  purchaseRequests   PurchaseRequest[]  @relation("PurchaseRequests")
  approvedRequests   PurchaseRequest[]  @relation("ApprovedRequests")

  @@map("users")
}

model Asset {
  id               String        @id @default(uuid())
  name             String
  type             String        @default("Other")
  manufacturer     String?
  serialNumber     String?       @unique
  purchasePrice    Decimal?
  purchaseDate     DateTime?
  depreciationMethod String?      @default("straight_line")
  usefulLifeYears   Int?         @default(5)
  salvageValue      Decimal?     @default(0)
  status           AssetStatus   @default(AVAILABLE)
  location         String?
  imageUrl         String?
  propertyNumber   String?
  remarks          String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  assignedTo       String?
  warrantyExpiry   DateTime?
  warrantyNotes     String?
  deletedAt        DateTime?

  disposalReason   String?           @db.Text
  disposalDate     DateTime?
  disposalMethod   DisposalMethod?

  supplierId     String?
  supplier       Supplier? @relation(fields: [supplierId], references: [id])

  assignments     Assignment[]
  maintenanceLogs MaintenanceLog[]
  maintenanceSchedules MaintenanceSchedule[]
  guestTokens     GuestToken[]
  notifications   Notification[]

  @@map("assets")
}

model Assignment {
  id            String           @id @default(uuid())
  assetId       String
  userId        String?
  personnelId   String?
  assignedTo    String?
  assignedAt    DateTime         @default(now())
  returnedAt    DateTime?
  condition     String?
  notes         String?
  agreementText String?          // Resolved agreement content (separate from general notes)
  agreementId   String?          // FK to the template used for this issuance
  bulkBatchId   String?          // Groups multiple assets issued together (1 agreement → N assets)
  recipientSignedAt DateTime?    // Digital recipient sign-off timestamp
  recipientSignatureName String? // Typed recipient sign-off name
  recipientSignatureMethod String? // typed, qr, imported
  recipientSignatureIp String?   // IP address captured during sign-off
  agreementDocumentId String?     // Immutable agreement document snapshot
  agreementDocument   AgreementDocument? @relation(fields: [agreementDocumentId], references: [id], onDelete: SetNull)
  asset         Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user          User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  personnel     Personnel?       @relation("PersonnelAssignments", fields: [personnelId], references: [id], onDelete: SetNull)
  agreement     AgreementTemplate? @relation("AssignmentAgreement", fields: [agreementId], references: [id], onDelete: SetNull)

  @@map("assignments")
}

model MaintenanceLog {
  id            String    @id @default(uuid())
  assetId       String
  technicianName String
  description    String
  cost           Decimal   @default(0)
  date           DateTime  @default(now())
  createdAt      DateTime  @default(now())

  asset         Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("maintenance_logs")
}

enum AuditSeverity {
  LOW
  MEDIUM
  HIGH
}

model AuditLog {
  id           String        @id @default(uuid())
  entityType   String
  entityId     String
  action       String
  field        String?
  oldValue     String?
  newValue     String?
  summary      String?
  severity     AuditSeverity  @default(LOW)
  userAgent    String?
  oldImageUrl  String?
  performedById String
  performedAt  DateTime      @default(now())
  ipAddress    String?

  performedBy  User          @relation("PerformedBy", fields: [performedById], references: [id])

  @@map("audit_logs")
}

model GuestToken {
  id          String   @id @default(uuid())
  assetId     String
  token       String   @unique
  expiresAt   DateTime
  maxAccess   Int      @default(1)
  accessCount Int      @default(0)
  createdAt   DateTime @default(now())

  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("guest_tokens")
}

model LabelTemplate {
  id        String   @id @default(uuid())
  name      String
  format    String
  config    String   @default("{}")
  createdById String
  createdAt DateTime @default(now())

  createdBy User     @relation(fields: [createdById], references: [id])

  @@map("label_templates")
}

model BackupLog {
  id            String     @id @default(uuid())
  status        BackupStatus @default(PENDING)
  destination   String
  filePath      String?
  encryptedSize Int?
  createdAt     DateTime   @default(now())

  @@map("backup_logs")
}

model LookupValue {
  id        Int            @id @default(autoincrement())
  category  LookupCategory
  value     String
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([category, value])
  @@map("lookup_values")
}

enum Role {
  ADMIN
  STAFF_ADMIN
  STAFF
  GUEST
}

enum AssetStatus {
  AVAILABLE
  PENDING_ASSIGNMENT
  ASSIGNED
  MAINTENANCE
  RETIRED
  LOST
}

enum DisposalMethod {
  DONATED
  SOLD
  SCRAPPED
  RETURNED_TO_VENDOR
  OTHER
}

enum LookupCategory {
  ASSET_TYPE
  MANUFACTURER
  LOCATION
  ASSIGNED_TO
}

enum BackupStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum NotificationType {
  WARRANTY_EXPIRING
  MAINTENANCE_OVERDUE
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  message   String
  assetId   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  asset     Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Personnel {
  id                String   @id @default(uuid())
  fullName          String
  designation       String?
  project           String?
  projectYear       String?
  email             String?   @unique
  phone             String?
  hiredDate         DateTime?
  employmentHistory String? @default("")
  personnelType          String   @default("employee")
  contractDurationMonths Int?
  contractStartDate      DateTime?
  contractEndDate        DateTime?
  signedAgreementPath    String?
  status            String   @default("active")  // active, inactive, resigned
  isReadyForIssuance Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt


  institutionId     Int?
  institution       InstitutionLookup? @relation("PersonnelInstitution", fields: [institutionId], references: [id])
  projectId         Int?
  projectLookup     ProjectLookup?     @relation("PersonnelProject", fields: [projectId], references: [id])
  designationId     Int?
  designationLookup DesignationLookup? @relation("PersonnelDesignation", fields: [designationId], references: [id])

  assignments       Assignment[] @relation("PersonnelAssignments")
  agreementDocuments AgreementDocument[] @relation("AgreementDocumentPersonnel")
  historyLogs       ProfileHistory[] @relation("PersonnelHistory")

  @@map("personnel")
}

model InstitutionLookup {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  status    String      @default("active")  // active, inactive
  createdAt DateTime    @default(now())
  personnel Personnel[] @relation("PersonnelInstitution")
  @@map("institution_lookup")
}

model ProjectLookup {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  status    String      @default("active")  // active, inactive, completed, archived
  createdAt DateTime    @default(now())
  personnel Personnel[] @relation("PersonnelProject")
  @@map("project_lookup")
}

model DesignationLookup {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  status    String      @default("active")  // active, inactive
  createdAt DateTime    @default(now())
  personnel Personnel[] @relation("PersonnelDesignation")
  @@map("designation_lookup")
}

model ProfileHistory {
  id              Int       @id @default(autoincrement())
  profileId       String
  designation     String?
  institutionName String?
  projectName     String?
  projectYear     String?
  hiredDate       DateTime?
  loggedAt        DateTime  @default(now())
  profile         Personnel @relation("PersonnelHistory", fields: [profileId], references: [id], onDelete: Cascade)
  @@map("profile_history")
}

model AgreementTemplate {
  id                     String   @id @default(uuid())
  name                   String   @default("Default")
  title                  String   @default("ISSUANCE & ACCOUNTABILITY AGREEMENT")
  content                String   @default("")
  headerLogo             String?  // file path for the project logo (e.g. /uploads/logos/logo-abc123.png)
  defaultLogo            String?  // path to a system-wide default logo fallback
  isDefault              Boolean  @default(false)
  defaultPropertyOfficer String?  // default name for Property Officer signatory
  defaultAuthorizedRep   String?  // default name for Authorized Representative signatory
  currentVersion         Int      @default(1)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  assignments            Assignment[] @relation("AssignmentAgreement")
  documents              AgreementDocument[] @relation("AgreementDocumentTemplate")
  versions               AgreementTemplateVersion[]

  @@map("agreement_templates")
}

model AgreementTemplateVersion {
  id                     String   @id @default(uuid())
  templateId             String
  versionNumber          Int
  name                   String
  title                  String
  content                String   @db.Text
  headerLogo             String?
  defaultPropertyOfficer String?
  defaultAuthorizedRep   String?
  changeSummary          String?
  createdAt              DateTime @default(now())

  template               AgreementTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  documents              AgreementDocument[] @relation("AgreementDocumentTemplateVersion")

  @@unique([templateId, versionNumber])
  @@index([templateId])
  @@map("agreement_template_versions")
}

model AgreementDocument {
  id                         String   @id @default(uuid())
  documentNumber             String   @unique
  templateId                 String?
  templateVersionId          String?
  templateVersion            Int?
  title                      String
  resolvedText               String   @db.Text
  headerLogo                 String?
  bulkBatchId                String?
  personnelId                String?
  personnelNameSnapshot      String
  designationSnapshot        String?
  projectSnapshot            String?
  institutionSnapshot        String?
  assetSnapshot              Json
  propertyOfficerName        String?
  authorizedRepName          String?
  status                     String   @default("issued")
  issuedAt                   DateTime @default(now())
  issuedById                 String
  recipientSignedAt          DateTime?
  recipientSignatureName     String?
  recipientSignatureMethod   String?
  recipientSignatureIp       String?
  signedPdfPath              String?
  signedUploadedAt           DateTime?
  signedUploadedById         String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  template                   AgreementTemplate? @relation("AgreementDocumentTemplate", fields: [templateId], references: [id], onDelete: SetNull)
  templateVersionRecord      AgreementTemplateVersion? @relation("AgreementDocumentTemplateVersion", fields: [templateVersionId], references: [id], onDelete: SetNull)
  personnel                  Personnel? @relation("AgreementDocumentPersonnel", fields: [personnelId], references: [id], onDelete: SetNull)
  issuedBy                   User @relation("AgreementDocumentIssuedBy", fields: [issuedById], references: [id])
  signedUploadedBy           User? @relation("AgreementDocumentSignedUploadedBy", fields: [signedUploadedById], references: [id], onDelete: SetNull)
  assignments                Assignment[]

  @@index([bulkBatchId])
  @@index([personnelId])
  @@index([templateVersionId])
  @@index([issuedAt])
  @@map("agreement_documents")
}

model MaintenanceSchedule {
  id            String   @id @default(uuid())
  assetId       String
  title         String
  scheduledDate DateTime
  notes         String?
  status        String   @default("pending")
  completedAt   DateTime?
  frequency     String?  @default("none")
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  asset         Asset    @relation(fields: [assetId], references: [id])

  @@map("maintenance_schedules")
}

model Supplier {
  id            String   @id @default(uuid())
  name          String
  contactPerson String?
  email         String?
  phone         String?
  website       String?
  notes         String?   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  assets        Asset[]

  @@map("suppliers")
}

model PurchaseRequest {
  id            String    @id @default(uuid())
  assetName     String
  type          String
  reason        String
  status        String    @default("PENDING")
  notes         String?
  requestedById String
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  requestedBy   User      @relation("PurchaseRequests", fields: [requestedById], references: [id])
  approvedBy    User?     @relation("ApprovedRequests", fields: [approvedById], references: [id])

  @@map("purchase_requests")
}