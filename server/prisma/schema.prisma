generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  username        String    @unique
  email           String    @unique
  passwordHash    String
  role            Role      @default(STAFF)
  twoFactorSecret String?
  twoFactorEnabled Boolean  @default(false)
  backupCodes     String   @default("[]")
  fullName        String?
  status          String    @default("active")
  lastLogin       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignments   Assignment[]
  auditLogs     AuditLog[]    @relation("PerformedBy")
  labelTemplates LabelTemplate[]

  @@map("users")
}

model Asset {
  id               String        @id @default(uuid())
  name             String
  type             String        @default("Other")
  manufacturer     String?
  serialNumber     String?       @unique
  purchasePrice    Decimal?
  purchaseDate     DateTime?
  status           AssetStatus   @default(AVAILABLE)
  location         String?
  imageUrl         String?
  propertyNumber   String?
  remarks          String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  assignedTo       String?
  warrantyExpiry   DateTime?
  warrantyNotes     String?
  deletedAt        DateTime?

  assignments     Assignment[]
  maintenanceLogs MaintenanceLog[]
  maintenanceSchedules MaintenanceSchedule[]
  guestTokens     GuestToken[]
  notifications   Notification[]

  @@map("assets")
}

model Assignment {
  id            String           @id @default(uuid())
  assetId       String
  userId        String?
  personnelId   String?
  assignedTo    String?
  assignedAt    DateTime         @default(now())
  returnedAt    DateTime?
  condition     String?
  notes         String?
  asset         Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user          User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  personnel     Personnel?       @relation("PersonnelAssignments", fields: [personnelId], references: [id], onDelete: SetNull)

  @@map("assignments")
}

model MaintenanceLog {
  id            String    @id @default(uuid())
  assetId       String
  technicianName String
  description    String
  cost           Decimal   @default(0)
  date           DateTime  @default(now())
  createdAt      DateTime  @default(now())

  asset         Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("maintenance_logs")
}

enum AuditSeverity {
  LOW
  MEDIUM
  HIGH
}

model AuditLog {
  id           String        @id @default(uuid())
  entityType   String
  entityId     String
  action       String
  field        String?
  oldValue     String?
  newValue     String?
  summary      String?
  severity     AuditSeverity  @default(LOW)
  userAgent    String?
  oldImageUrl  String?
  performedById String
  performedAt  DateTime      @default(now())
  ipAddress    String?

  performedBy  User          @relation("PerformedBy", fields: [performedById], references: [id])

  @@map("audit_logs")
}

model GuestToken {
  id          String   @id @default(uuid())
  assetId     String
  token       String   @unique
  expiresAt   DateTime
  maxAccess   Int      @default(1)
  accessCount Int      @default(0)
  createdAt   DateTime @default(now())

  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("guest_tokens")
}

model LabelTemplate {
  id        String   @id @default(uuid())
  name      String
  format    String
  config    String   @default("{}")
  createdById String
  createdAt DateTime @default(now())

  createdBy User     @relation(fields: [createdById], references: [id])

  @@map("label_templates")
}

model BackupLog {
  id            String     @id @default(uuid())
  status        BackupStatus @default(PENDING)
  destination   String
  filePath      String?
  encryptedSize Int?
  createdAt     DateTime   @default(now())

  @@map("backup_logs")
}

model LookupValue {
  id        Int            @id @default(autoincrement())
  category  LookupCategory
  value     String
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([category, value])
  @@map("lookup_values")
}

enum Role {
  ADMIN
  STAFF_ADMIN
  STAFF
  GUEST
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
  LOST
}

enum LookupCategory {
  ASSET_TYPE
  MANUFACTURER
  LOCATION
  ASSIGNED_TO
}

enum BackupStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum NotificationType {
  WARRANTY_EXPIRING
  MAINTENANCE_OVERDUE
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  message   String
  assetId   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  asset     Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Personnel {
  id                String   @id @default(uuid())
  fullName          String
  designation       String?
  project           String?
  projectYear       String?
  email             String?   @unique
  phone             String?
  hiredDate         DateTime?
  employmentHistory String? @default("")
  status            String   @default("active")  // active, inactive, resigned
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  institutionId     Int?
  institution       InstitutionLookup? @relation("PersonnelInstitution", fields: [institutionId], references: [id])
  projectId         Int?
  projectLookup     ProjectLookup?     @relation("PersonnelProject", fields: [projectId], references: [id])
  designationId     Int?
  designationLookup DesignationLookup? @relation("PersonnelDesignation", fields: [designationId], references: [id])

  assignments       Assignment[] @relation("PersonnelAssignments")
  historyLogs       ProfileHistory[] @relation("PersonnelHistory")

  @@map("personnel")
}

model InstitutionLookup {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  status    String      @default("active")  // active, inactive
  createdAt DateTime    @default(now())
  personnel Personnel[] @relation("PersonnelInstitution")
  @@map("institution_lookup")
}

model ProjectLookup {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  status    String      @default("active")  // active, inactive, completed, archived
  createdAt DateTime    @default(now())
  personnel Personnel[] @relation("PersonnelProject")
  @@map("project_lookup")
}

model DesignationLookup {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  status    String      @default("active")  // active, inactive
  createdAt DateTime    @default(now())
  personnel Personnel[] @relation("PersonnelDesignation")
  @@map("designation_lookup")
}

model ProfileHistory {
  id              Int       @id @default(autoincrement())
  profileId       String
  designation     String?
  institutionName String?
  projectName     String?
  projectYear     String?
  hiredDate       DateTime?
  loggedAt        DateTime  @default(now())
  profile         Personnel @relation("PersonnelHistory", fields: [profileId], references: [id], onDelete: Cascade)
  @@map("profile_history")
}

model AgreementTemplate {
  id        String   @id @default(uuid())
  name      String   @default("Default")
  content   String   @default("")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agreement_templates")
}

model MaintenanceSchedule {
  id            String   @id @default(uuid())
  assetId       String
  title         String
  scheduledDate DateTime
  notes         String?
  status        String   @default("pending")
  completedAt   DateTime?
  frequency     String?  @default("none")
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  asset         Asset    @relation(fields: [assetId], references: [id])

  @@map("maintenance_schedules")
}